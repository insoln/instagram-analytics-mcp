# ============================================
# Social Analytics MCP Server Configuration
# ============================================

# --------------------------------------------
# Mode selection
# --------------------------------------------
# stdio-static (default) — stdin/stdout, token from env vars below. Use with Claude Desktop.
# http-static            — HTTP server, token from env vars. Single-user HTTPS deployment.
# http-oauth             — HTTP server, Meta OAuth 2.1. Multi-tenant production deployment.
MCP_MODE=stdio-static

# --------------------------------------------
# stdio-static / http-static: provide tokens directly
# --------------------------------------------
# Instagram User Access Token with permissions:
#   instagram_business_basic, instagram_business_manage_insights
# Get from: https://developers.facebook.com/tools/explorer/
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token_here

# Optional: Instagram Business Account ID (auto-detected if omitted)
INSTAGRAM_ACCOUNT_ID=

# Optional: Instagram Graph API version (default: v23.0)
INSTAGRAM_API_VERSION=v23.0

# Facebook User Access Token with permissions: read_insights, pages_read_engagement
FACEBOOK_ACCESS_TOKEN=your_facebook_access_token_here

# Optional: Facebook Page ID (auto-detected via facebook_list_pages if omitted)
FACEBOOK_PAGE_ID=

# Optional: Facebook Graph API version (default: v22.0)
FACEBOOK_API_VERSION=v22.0

# Optional: Bearer token to protect the /mcp endpoint in http-static mode
# STATIC_TOKEN=your_secret_token_here

# --------------------------------------------
# http-static / http-oauth: HTTP server settings
# --------------------------------------------
PORT=3000
HOST=0.0.0.0

# Public base URL of this server (no trailing slash).
# Required for http-oauth (must match the Meta App redirect URI).
# Recommended for http-static — used for DNS rebinding protection (allowedHosts).
# Without it, only 'localhost' is allowed as the Host header in http-static mode.
# Example: SERVER_URL=https://mcp.example.com
SERVER_URL=

# --------------------------------------------
# http-oauth: Meta OAuth 2.1 multi-tenant mode
# --------------------------------------------

# Meta App credentials — create an app at https://developers.facebook.com
META_APP_ID=
META_APP_SECRET=

# Path for the Meta OAuth callback (default: /auth/meta/callback)
# The full redirect URI registered in Meta App must be: ${SERVER_URL}${META_CALLBACK_PATH}
# META_CALLBACK_PATH=/auth/meta/callback

# JWT signing key (EC P-256 private key as JSON JWK).
# If omitted, an ephemeral key is generated — tokens are lost on restart.
# Generate with:
#   node -e "const {generateKeyPairSync}=require('crypto'); const {privateKey}=generateKeyPairSync('ec',{namedCurve:'P-256'}); console.log(JSON.stringify(privateKey.export({format:'jwk'})))"
# JWT_PRIVATE_KEY_JWK={"kty":"EC","crv":"P-256","x":"...","y":"...","d":"..."}

# JWT access token expiry (default: 1h). Refresh tokens expire after 30 days.
# JWT_EXPIRY=1h

# --------------------------------------------
# Debug
# --------------------------------------------
# DEBUG=social-analytics-mcp
